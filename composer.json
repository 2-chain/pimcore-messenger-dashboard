{
    "name": "2chain/pimcore-messenger-dashboard",
    "description": "Pimcore admin dashboard for Symfony Messenger queues, with audit stats, delete/requeue, and permission gating.",
    "type": "pimcore-bundle",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/2-chain/pimcore-messenger-dashboard",
    "support": {
        "issues": "https://github.com/2-chain/pimcore-messenger-dashboard/issues",
        "source": "https://github.com/2-chain/pimcore-messenger-dashboard"
    },
    "require": {
        "php": "^8.2",
        "pimcore/pimcore": "^11.0 || ^12.0",
        "symfony/messenger": "^6.4 || ^7.0",
        "doctrine/orm": "^2.17 || ^3.0",
        "doctrine/migrations": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^12.0",
        "dama/doctrine-test-bundle": "^8.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "autoload": {
        "psr-4": { "TwoChain\\PimcoreMessengerDashboardBundle\\": "" }
    },
    "autoload-dev": {
        "psr-4": { "TwoChain\\PimcoreMessengerDashboardBundle\\Tests\\": "tests/" }
    },
    "extra": {
        "pimcore": {
            "bundles": ["TwoChain\\PimcoreMessengerDashboardBundle\\PimcoreMessengerDashboardBundle"]
        }
    }
}
